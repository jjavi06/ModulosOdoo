<odoo>
    <data>

        <!-- Accions -->
        <record id="action_taller_cotxe" model="ir.actions.act_window">
            <field name="name">Cotxes</field>
            <field name="res_model">taller.cotxe</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_taller_avaria" model="ir.actions.act_window">
            <field name="name">Avaries</field>
            <field name="res_model">taller.avaria</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menús -->
        <menuitem id="menu_taller_root" name="Taller"/>

        <menuitem id="menu_taller_cotxe"
                  name="Cotxes"
                  parent="menu_taller_root"
                  action="action_taller_cotxe"/>

        <menuitem id="menu_taller_avaria"
                  name="Avaries"
                  parent="menu_taller_root"
                  action="action_taller_avaria"/>

        <!-- Vista llista Cotxe -->
        <record id="view_taller_cotxe_list" model="ir.ui.view">
            <field name="name">view_taller_cotxe_list</field>
            <field name="model">taller.cotxe</field>
            <field name="arch" type="xml">
                <list string="Cotxes">
                    <field name="model"/>
                    <field name="matricula"/>
                    <field name="color"/>
                    <field name="dataCompra"/>
                </list>
            </field>
        </record>

        <!-- Vista formulari Cotxe -->
        <record id="view_taller_cotxe_form" model="ir.ui.view">
            <field name="name">view_taller_cotxe_form</field>
            <field name="model">taller.cotxe</field>
            <field name="arch" type="xml">
                <form string="Cotxe">
                    <sheet>
                        <group>
                            <field name="foto" widget="image"/>
                            <field name="model"/>
                            <field name="matricula"/>
                            <field name="color"/>
                            <field name="dataCompra"/>
                        </group>
                        <notebook>
                            <page string="Avaries">
                                <field name="avaria_ids">
                                    <list editable="bottom">
                                        <field name="nom"/>
                                        <field name="dataEntrada"/>
                                        <field name="dataSortida"/>
                                        <field name="preu"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista llista Avaria -->
        <record id="view_taller_avaria_list" model="ir.ui.view">
            <field name="name">view_taller_avaria_list</field>
            <field name="model">taller.avaria</field>
            <field name="arch" type="xml">
                <list string="Avaries">
                    <field name="nom"/>
                    <field name="cotxe_id"/>
                    <field name="dataEntrada"/>
                    <field name="dataSortida"/>
                    <field name="preu"/>
                </list>
            </field>
        </record>

        <!-- Vista formulari Avaria -->
        <record id="view_taller_avaria_form" model="ir.ui.view">
            <field name="name">view_taller_avaria_form</field>
            <field name="model">taller.avaria</field>
            <field name="arch" type="xml">
                <form string="Avaria">
                    <sheet>
                        <group>
                            <field name="nom"/>
                            <field name="cotxe_id"/>
                            <field name="descripcio"/>
                            <field name="dataEntrada"/>
                            <field name="dataSortida"/>
                            <field name="preu"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>
