<odoo>
    <data>

        <!-- *** VISTES EN LLISTA - PELICULA *** -->
        <record model="ir.ui.view" id="view_cinema_pelicula_list">
            <field name="name">view_cinema_pelicula_list</field>
            <field name="model">cinema.pelicula</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Pel·lícules">
                    <field name="titol"/>
                    <field name="director_id"/>
                    <field name="any"/>
                    <field name="antiguitat"/>
                    <field name="puntuacio"/>
                </list>
            </field>
        </record>

        <!-- *** VISTA SEARCH - PELICULA *** -->
        <record model="ir.ui.view" id="view_cinema_pelicula_search">
            <field name="name">view_cinema_pelicula_search</field>
            <field name="model">cinema.pelicula</field>
            <field name="type">search</field>
            <field name="arch" type="xml">
                <search string="Cerca de Pel·lícules">
                    <field name="titol"/>
                    <field name="director_id"/>
                    <field name="any"/>
                    <separator/>
                    <filter name="molt_bones_9" string="Molt bones (+9 punts)" domain="[('puntuacio', '&gt;', 9)]"/>
                    <filter name="molt_bones_8" string="Molt bones (+8 punts)" domain="[('puntuacio', '&gt;', 8)]"/>
                    <filter name="bones_6" string="Bones (+6 punts)" domain="[('puntuacio', '&gt;', 6)]"/>
                    <filter name="dolentes_5" string="Dolentes (-5 punts)" domain="[('puntuacio', '&lt;', 5)]"/>
                </search>
            </field>
        </record>

        <!-- *** VISTA FORMULARI - PELICULA *** -->
        <record model="ir.ui.view" id="view_cinema_pelicula_form">
            <field name="name">view_cinema_pelicula_form</field>
            <field name="model">cinema.pelicula</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Pel·lícula">
                    <sheet>
                        <group>
                            <group>
                                <field name="foto" widget="image" class="oe_avatar"/>
                            </group>
                            <group>
                                <field name="titol"/>
                                <field name="director_id"/>
                                <field name="pais"/>
                                <field name="any"/>
                                <field name="duracio"/>
                                <field name="puntuacio"/>
                                <field name="activo"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Resum">
                                <field name="resum" nolabel="1"/>
                            </page>
                            <page string="Actors">
                                <field name="actor_ids">
                                    <list>
                                        <field name="nom"/>
                                        <field name="cognom"/>
                                        <field name="data_naixement"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Gèneres">
                                <field name="genere_ids">
                                    <list>
                                        <field name="nom"/>
                                        <field name="num_pelicules"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>