<odoo>
    <data>

        <!-- *** VISTES EN LLISTA - ACTOR *** -->
        <record model="ir.ui.view" id="view_cinema_actor_list">
            <field name="name">view_cinema_actor_list</field>
            <field name="model">cinema.actor</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Actors">
                    <field name="nom"/>
                    <field name="cognom"/>
                    <field name="edat"/>
                    <field name="data_naixement"/>
                </list>
            </field>
        </record>

        <!-- *** VISTA KANBAN - ACTOR *** -->
        <record model="ir.ui.view" id="view_cinema_actor_kanban">
            <field name="name">view_cinema_actor_kanban</field>
            <field name="model">cinema.actor</field>
            <field name="type">kanban</field>
            <field name="arch" type="xml">
                <kanban>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click o_kanban_record">
                                <div class="o_kanban_image">
                                    <field name="foto" widget="image" class="oe_avatar"/>
                                </div>
                                <div class="o_kanban_details">
                                    <strong><field name="nom"/> <field name="cognom"/></strong>
                                    <div>Edat: <field name="edat"/></div>
                                    <div>Data naixement: <field name="data_naixement"/></div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- *** VISTA FORMULARI - ACTOR *** -->
        <record model="ir.ui.view" id="view_cinema_actor_form">
            <field name="name">view_cinema_actor_form</field>
            <field name="model">cinema.actor</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Actor">
                    <sheet>
                        <group>
                            <group>
                                <field name="foto" widget="image" class="oe_avatar"/>
                            </group>
                            <group>
                                <field name="nom"/>
                                <field name="cognom"/>
                                <field name="data_naixement"/>
                                <field name="edat" readonly="1"/>
                                <field name="activo"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Llista de pel·lícules">
                                <field name="pelicula_ids">
                                    <list>
                                        <field name="titol"/>
                                        <field name="any"/>
                                        <field name="puntuacio"/>
                                        <field name="pais"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Bibliografia">
                                <field name="bibliografia" nolabel="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>