<odoo>
    <data>

        <!-- *** VISTES EN LLISTA - GENERE *** -->
        <record model="ir.ui.view" id="view_cinema_genere_list">
            <field name="name">view_cinema_genere_list</field>
            <field name="model">cinema.genere</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Gèneres">
                    <field name="nom"/>
                    <field name="num_pelicules"/>
                </list>
            </field>
        </record>

        <!-- *** VISTA KANBAN - GENERE *** -->
        <record model="ir.ui.view" id="view_cinema_genere_kanban">
            <field name="name">view_cinema_genere_kanban</field>
            <field name="model">cinema.genere</field>
            <field name="type">kanban</field>
            <field name="arch" type="xml">
                <kanban>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click o_kanban_record">
                                <div class="o_kanban_image">
                                    <field name="foto" widget="image" class="oe_avatar"/>
                                </div>
                                <div class="o_kanban_details">
                                    <strong><field name="nom"/></strong>
                                    <div>Nombre pel·lícules: <field name="num_pelicules"/></div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- *** VISTA FORMULARI - GENERE *** -->
        <record model="ir.ui.view" id="view_cinema_genere_form">
            <field name="name">view_cinema_genere_form</field>
            <field name="model">cinema.genere</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Gènere">
                    <sheet>
                        <group>
                            <group>
                                <field name="foto" widget="image" class="oe_avatar"/>
                            </group>
                            <group>
                                <field name="nom"/>
                                <field name="activo"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Llista de pel·lícules">
                                <field name="pelicula_ids">
                                    <list>
                                        <field name="titol"/>
                                        <field name="director_id"/>
                                        <field name="any"/>
                                        <field name="puntuacio"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>