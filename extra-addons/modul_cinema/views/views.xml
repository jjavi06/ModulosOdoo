<odoo>
    <data>

        <!-- *** ACCIONS - CINEMA *** -->
        <record model="ir.actions.act_window" id="action_cinema_pelicula">
            <field name="name">Pel·lícules</field>
            <field name="res_model">cinema.pelicula</field>
            <field name="view_mode">list,form</field>
        </record>

        <record model="ir.actions.act_window" id="action_cinema_director">
            <field name="name">Directors</field>
            <field name="res_model">cinema.director</field>
            <field name="view_mode">list,form</field>
        </record>

        <record model="ir.actions.act_window" id="action_cinema_actor">
            <field name="name">Actors</field>
            <field name="res_model">cinema.actor</field>
            <field name="view_mode">list,form</field>
        </record>

        <record model="ir.actions.act_window" id="action_cinema_genere">
            <field name="name">Gèneres</field>
            <field name="res_model">cinema.genere</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- *** MENUS - CINEMA *** -->
        <menuitem id="cinema_menu_root" name="Cinema"/>
        <menuitem id="cinema_menu_gestion" name="Gestió Cinema" parent="cinema_menu_root"/>
        
        <menuitem id="cinema_menu_pelicula" name="Pel·lícules" parent="cinema_menu_gestion"
            action="action_cinema_pelicula"/>
        <menuitem id="cinema_menu_director" name="Directors" parent="cinema_menu_gestion"
            action="action_cinema_director"/>
        <menuitem id="cinema_menu_actor" name="Actors" parent="cinema_menu_gestion"
            action="action_cinema_actor"/>
        <menuitem id="cinema_menu_genere" name="Gèneres" parent="cinema_menu_gestion"
            action="action_cinema_genere"/>

        <!-- *** VISTES EN LLISTA - PELICULA *** -->
        <record model="ir.ui.view" id="view_cinema_pelicula_list">
            <field name="name">view_cinema_pelicula_list</field>
            <field name="model">cinema.pelicula</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Pel·lícules">
                    <field name="titol"/>
                    <field name="director_id"/>
                    <field name="any"/>
                    <field name="antiguitat"/>
                    <field name="puntuacio"/>
                </list>
            </field>
        </record>

        <!-- *** VISTES EN LLISTA - DIRECTOR *** -->
        <record model="ir.ui.view" id="view_cinema_director_list">
            <field name="name">view_cinema_director_list</field>
            <field name="model">cinema.director</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Directors">
                    <field name="nom"/>
                    <field name="cognom"/>
                    <field name="edat"/>
                    <field name="data_naixement"/>
                </list>
            </field>
        </record>

        <!-- *** VISTES EN LLISTA - ACTOR *** -->
        <record model="ir.ui.view" id="view_cinema_actor_list">
            <field name="name">view_cinema_actor_list</field>
            <field name="model">cinema.actor</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Actors">
                    <field name="nom"/>
                    <field name="cognom"/>
                    <field name="edat"/>
                    <field name="data_naixement"/>
                </list>
            </field>
        </record>

        <!-- *** VISTES EN LLISTA - GENERE *** -->
        <record model="ir.ui.view" id="view_cinema_genere_list">
            <field name="name">view_cinema_genere_list</field>
            <field name="model">cinema.genere</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Gèneres">
                    <field name="nom"/>
                    <field name="num_pelicules"/>
                </list>
            </field>
        </record>

    </data>
</odoo>