<odoo>
    <data>

        <!-- *** VISTES EN LLISTA - DIRECTOR *** -->
        <record model="ir.ui.view" id="view_cinema_director_list">
            <field name="name">view_cinema_director_list</field>
            <field name="model">cinema.director</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Directors">
                    <field name="nom"/>
                    <field name="cognom"/>
                    <field name="edat"/>
                    <field name="data_naixement"/>
                </list>
            </field>
        </record>

        <!-- *** VISTA FORMULARI - DIRECTOR *** -->
        <record model="ir.ui.view" id="view_cinema_director_form">
            <field name="name">view_cinema_director_form</field>
            <field name="model">cinema.director</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Director">
                    <sheet>
                        <group>
                            <group>
                                <field name="foto" widget="image" class="oe_avatar"/>
                            </group>
                            <group>
                                <field name="nom"/>
                                <field name="cognom"/>
                                <field name="data_naixement"/>
                                <field name="edat" readonly="1"/>
                                <field name="activo"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Llista de pel·lícules">
                                <field name="pelicula_ids">
                                    <tree>
                                        <field name="titol"/>
                                        <field name="any"/>
                                        <field name="puntuacio"/>
                                        <field name="pais"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Bibliografia">
                                <field name="bibliografia" nolabel="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>